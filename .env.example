# Copia este archivo como .env y completa los valores

# Base de datos SQLite (Railway provee DATABASE_URL para Postgres, pero usamos SQLite local)
DATABASE_URI=file:./db.sqlite

# Secreto para Payload (cambia esto por una cadena larga y aleatoria)
PAYLOAD_SECRET=cambia-esto-por-algo-muy-secreto-y-largo

# URL del sitio en producción (Railway te dará esta URL)
NEXT_PUBLIC_SERVER_URL=https://tu-app.railway.app
